server:
  port: ${SERVER_PORT:8080}

spring:
  datasource:
    url: ${DATASOURCE_URL:jdbc:mysql://localhost:3306/sclass}
    username: ${DATASOURCE_USERNAME:root}
    password: ${DATASOURCE_PASSWORD:}
    driver-class-name: com.mysql.cj.jdbc.Driver
    hikari:
      maximum-pool-size: ${HIKARI_MAX_POOL:5}
      minimum-idle: ${HIKARI_MIN_IDLE:2}
  jpa:
    hibernate:
      ddl-auto: ${DDL_AUTO:update}
    show-sql: false
    properties:
      hibernate:
        format_sql: true
  data:
    redis:
      host: ${REDIS_HOST:localhost}
      port: ${REDIS_PORT:6379}
      password: ${REDIS_PASSWORD:}
  mail:
    host: ${SMTP_HOST:}
    port: ${SMTP_PORT:587}
    username: ${SMTP_USERNAME:}
    password: ${SMTP_PASSWORD:}
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true
  quartz:
    job-store-type: jdbc
    jdbc:
      initialize-schema: always
    properties:
      org.quartz.threadPool.threadCount: 5
      org.quartz.jobStore.isClustered: true
      org.quartz.jobStore.clusterCheckinInterval: 20000

cors:
  allow:
    origins: ${CORS_ALLOW_ORIGINS:}

email:
  smtp:
    enabled: ${SMTP_ENABLED:false}

auth:
  jwt:
    secret-key: ${JWT_SECRET_KEY:your-secret-key-must-be-at-least-256-bits}
    access-exp: ${JWT_ACCESS_EXP:3600}
    refresh-exp: ${JWT_REFRESH_EXP:604800}
  token-encryption:
    secret-key: ${TOKEN_ENCRYPTION_KEY:your-32-byte-aes-encryption-key!}

oauth2:
  providers:
    google:
      client-id: ${GOOGLE_CLIENT_ID:}
    kakao:
      client-id: ${KAKAO_CLIENT_ID:}

alimtalk:
  enabled: ${ALIMTALK_ENABLED:false}
  service-id: ${ALIMTALK_SERVICE_ID:}
  access-key: ${ALIMTALK_ACCESS_KEY:}
  secret-key: ${ALIMTALK_SECRET_KEY:}
  plus-friend-id: ${ALIMTALK_PLUS_FRIEND_ID:}
  app-base-url: ${ALIMTALK_APP_BASE_URL:}

management:
  endpoints:
    web:
      exposure:
        include: health, info, metrics
  endpoint:
    health:
      show-details: never
  auth:
    username: ${ACTUATOR_USERNAME:admin}
    password: ${ACTUATOR_PASSWORD:changeme}
  cloudwatch:
    metrics:
      enabled: ${CLOUDWATCH_METRICS_ENABLED:false}
      namespace: ${CLOUDWATCH_NAMESPACE:SClass/Supporters}
      step: ${CLOUDWATCH_STEP:60}
      region: ${AWS_REGION:ap-northeast-1}

cloud:
  aws:
    s3:
      bucket: ${S3_BUCKET:sclass-supporters}
      region: ${S3_REGION:ap-northeast-2}
      access-key: ${S3_ACCESS_KEY:}
      secret-key: ${S3_SECRET_KEY:}
      endpoint: ${S3_ENDPOINT:}

nicepay:
  client-key: ${NICE_PAY_CLIENT_KEY:}
  secret-key: ${NICE_PAY_SECRET_KEY:}
  base-url: ${NICE_PAY_API_URL:https://api.nicepay.co.kr}

sclass:
  frontend-url: ${FRONTEND_URL:https://sclass.aura.co.kr}
