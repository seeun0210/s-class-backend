server:
  port: ${SERVER_PORT:8082}

spring:
  datasource:
    url: ${DATASOURCE_URL:jdbc:mysql://localhost:3306/sclass}
    username: ${DATASOURCE_USERNAME:root}
    password: ${DATASOURCE_PASSWORD:}
    driver-class-name: com.mysql.cj.jdbc.Driver
  jpa:
    hibernate:
      ddl-auto: ${DDL_AUTO:update}
    show-sql: false
    properties:
      hibernate:
        format_sql: true
  mail:
    host: ${SMTP_HOST:}
    port: ${SMTP_PORT:587}
    username: ${SMTP_USERNAME:}
    password: ${SMTP_PASSWORD:}
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true

cors:
  allow:
    origins: ${CORS_ALLOW_ORIGINS:}

email:
  smtp:
    enabled: ${SMTP_ENABLED:false}

auth:
  jwt:
    secret-key: ${JWT_SECRET_KEY:your-secret-key-must-be-at-least-256-bits}
    access-exp: ${JWT_ACCESS_EXP:3600}
    refresh-exp: ${JWT_REFRESH_EXP:604800}
  token-encryption:
    secret-key: ${TOKEN_ENCRYPTION_KEY:your-32-byte-aes-encryption-key!}

oauth2:
  providers:
    google:
      client-id: ${GOOGLE_CLIENT_ID:}
    kakao:
      client-id: ${KAKAO_CLIENT_ID:}

cloud:
  aws:
    s3:
      bucket: ${S3_BUCKET:sclass-backoffice}
      region: ${S3_REGION:ap-northeast-2}
      access-key: ${S3_ACCESS_KEY:}
      secret-key: ${S3_SECRET_KEY:}
      endpoint: ${S3_ENDPOINT:}
